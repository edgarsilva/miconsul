# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib
bin/*

# Test binary, built with "go test -c"
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
tmp/

# IDE specific files
.vscode

# .env file
.env

# node.js and node_modules (for Tailwind CSS)
node_modules

# Code generated by Templ
# *_templ.go
*_templ.txt

# Don't include the database file
database/*.sqlite*

# Don't Local store DB and Session
store/

# Don't include tmp/dev/test uploads
assets/

# Don't include public/global.css, generated by tailwindcss
public/global.css
public/**/*.fiber.*

# Generated local coverage artifacts
coverage/c.out
coverage/c.filtered.out
coverage/c.html
coverage/c.filtered.html
coverage/summary.txt
coverage/summary.filtered.txt
