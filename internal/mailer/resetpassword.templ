package mailer

templ ResetPasswordTpl(locale, username, resetURL string) {
	@EmailWrapper() {
		<p>
			{ l(locale, "email.greeting") }
			<b>{ username }</b>
			<br/>
			<br/>
			<span>{ l(locale, "email.reset_password_body") }</span>
			<br/>
			<br/>
			<a href={ templ.URL(resetURL) }><b>{ l(locale, "email.reset_password_cta") }</b></a>!
		</p>
	}
}
