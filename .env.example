# Application
APP_NAME=myapp
APP_ENV=development
APP_PROTOCOL=http
APP_DOMAIN=localhost:3000
RATE_LIMITER_ENABLED=true

# SECRETS
COOKIE_SECRET=
JWT_SECRET=

# Database Path
DB_PATH=database/app.sqlite
SESSION_PATH=database/fiber_session.sqlite

# Email/SMTP
EMAIL_SENDER=
EMAIL_SECRET=
EMAIL_FROM_ADDR=
EMAIL_SMTP_URL="smtp.gmail.com"

# Goose Migrations
GOOSE_DRIVER=sqlite3
GOOSE_DBSTRING=./database/app.sqlite
GOOSE_MIGRATION_DIR=./database/migrations

# Logto
LOGTO_URL=
LOGTO_APP_ID=
LOGTO_APP_SECRET=
LOGTO_RESOURCE=

# Telemetry
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_INSECURE=
OTEL_SERVICE_NAME=miconsul
OTEL_TRACER_SERVER=miconsul.server
OTEL_TRACER_AUTH=miconsul.auth

# Jobs (Asynq + Valkey)
JOBS_ENABLED=false
JOBS_UI_ENABLED=false
VALKEY_HOST=127.0.0.1
VALKEY_PORT=6379
VALKEY_PASSWORD=
VALKEY_DB=0

# Assets
ASSETS_DIR=./assets

PORT=3000
